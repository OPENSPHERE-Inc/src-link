{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git rev-list:*)",
      "Bash(git branch:*)",
	    "Bash(git ls-tree:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(cmake:*)"
    ],
    "deny": [
	    "Read(.env.production)",
      "Bash(git push:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr lock:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr create:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
